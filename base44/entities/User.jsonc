{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "walletBalance": {
      "type": "number",
      "default": 10000,
      "description": "User's wallet balance in dollars"
    }
  }
}