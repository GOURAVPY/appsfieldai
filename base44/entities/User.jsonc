{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "requireListingApproval": {
      "type": "boolean",
      "default": true,
      "description": "Whether new SaaS listings require admin approval"
    },
    "walletBalance": {
      "type": "number",
      "default": 0,
      "description": "User's wallet balance"
    }
  }
}